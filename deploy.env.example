# Production deploy target. Copy to deploy.env (gitignored) and fill in real values.
# Used by scripts/publish.sh. Keeps server coordinates out of the public repo.
DEPLOY_USER=your_ssh_user
DEPLOY_HOST=your.server.ip.or.host
DEPLOY_PORT=65002
DEPLOY_SSH_KEY=$HOME/.ssh/hostinger_deploy
DEPLOY_WP_PATH=/home/your_ssh_user/domains/example.com/public_html
